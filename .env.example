OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1
COMPLEX_ANALYSIS_MODEL=gpt-4o-mini

# Server
SERVER_PORT=8001

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=omnistatus
MONGO_COLL_NAME=events
MONGO_COLL_VICTORIA=victoria_history

# Complex Analysis
ENABLE_COMPLEX_ANALYSIS_CRON=1
COMPLEX_ANALYSIS_LOOKBACK_HOURS=3
COMPLEX_ANALYSIS_CRON_HOURS=3
COMPLEX_ANALYSIS_MAX_EVENTS=500

# Prompts (configurable)
SYSTEM_PROMPT=
COMPLEX_ANALYSIS_PROMPT=
COMPLEX_ANALYSIS_SUMMARY_MAX_CHARS=100

# Telegram
ENABLE_TELEGRAM=0
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_MAX_CHARS=100
