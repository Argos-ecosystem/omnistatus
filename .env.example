# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini
COMPLEX_ANALYSIS_MODEL=gpt-4.1-mini

# Server
SERVER_PORT=8001

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=omnistatus
MONGO_COLL_NAME=events
MONGO_COLL_VICTORIA=victoria_history

# Complex Analysis (cron → Telegram)
ENABLE_COMPLEX_ANALYSIS_CRON=1
COMPLEX_ANALYSIS_LOOKBACK_HOURS=12
COMPLEX_ANALYSIS_CRON_HOURS=3
COMPLEX_ANALYSIS_MAX_EVENTS=500
COMPLEX_ANALYSIS_SUMMARY_MAX_CHARS=200

# Custom Analysis (API endpoint)
CUSTOM_ANALYSIS_SUMMARY_MAX_CHARS=200

# Telegram
ENABLE_TELEGRAM=0
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
